{
  "manifest_version": 3,
  "name": "PromptMate",
  "version": "0.3.0",
  "description": "Your prompts. One click away.",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://claude.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
        "128": "icons/icon128.png",
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "dist/background.bundle.js"
  },
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*"],
      "js": ["dist/gpt-content.bundle.js"]
    },
    {
      "matches": ["*://claude.ai/*"],
      "js": ["claude-content.js"]
    }
  ]
}