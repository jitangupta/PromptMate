{
  "name": "promptmate",
  "version": "1.0.0",
  "description": "Chrome extension that adds a prompt-management sidebar to ChatGPT and Claude. Compose prompts from a reusable body plus tone and output-format presets, then insert them into the host with one click.",
  "main": "background.js",
  "scripts": {
    "build": "rollup -c",
    "build:package": "node scripts/package/build-package.js",
    "release": "npm run build && npm run build:package",
    "test": "jest",
    "watch": "rollup -c -w"
  },
  "keywords": [
    "chrome-extension",
    "chatgpt",
    "claude",
    "prompts",
    "productivity",
    "llm",
    "ai"
  ],
  "author": "Jitan Gupta <hi@jitangupta.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jitangupta/PromptMate.git"
  },
  "bugs": {
    "url": "https://github.com/jitangupta/PromptMate/issues"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "archiver": "^7.0.1",
    "fs-extra": "^11.3.0",
    "rollup": "^2.79.2",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-terser": "^7.0.2"
  }
}
